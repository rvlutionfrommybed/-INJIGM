# Store these as GitHub Codespaces secrets. Never commit real values.
GH_ACCOUNT=12345678-01
GH_APPKEY=your_mock_app_key
GH_APPSECRET=your_mock_app_secret
SYMBOL=005930
MARKET_CODE=J
EXCHANGE_CODE=KRX
# Multi-market scanner candidates are built in:
# Korean session: KODEX 200(069500), Samsung(005930), SK Hynix(000660)
# US session: TQQQ, NVDA, SOXL
KR_CANDIDATES=069500:KODEX200,005930:삼성전자,000660:SK하이닉스
US_CANDIDATES=TQQQ:TQQQ:NAS,NVDA:엔비디아:NAS,SOXL:SOXL:NAS
# Optional test override: FORCE_MARKET=kr or FORCE_MARKET=us
FORCE_MARKET=auto
ENABLE_US_TRADING=false

# Optional strategy settings
PRICE_OFFSET_KRW=1000
LIMIT_OFFSET_PCT=0.003
ORDER_QUANTITY=1
POLL_INTERVAL_SECONDS=300
ORDER_VERIFY_DELAY_SECONDS=10
REQUEST_INTERVAL_SECONDS=1.3
RATE_LIMIT_RETRY_SECONDS=2.5
RATE_LIMIT_RETRIES=3
REQUEST_TIMEOUT_SECONDS=10
MAX_RETRIES=2
DRY_RUN=true
TRADING_WINDOW_MODE=regular
ORDER_DIVISION=00
OVERSEAS_ORDER_DIVISION=00

# Finance-engineering signal settings
STRATEGY_MODE=finance
ANNUAL_DRIFT=0.05
ANNUAL_VOLATILITY=0.20
SIMULATION_DAYS=20
SIMULATION_PATHS=500
MIN_EXPECTED_RETURN=0.001
MAX_LOSS_PROBABILITY=0.48
LOSS_PROBABILITY_PENALTY=0.5
TAKE_PROFIT_PCT=0.01
STOP_LOSS_PCT=0.01
